# Copia este archivo a .env y ajusta los valores.
# (.env esta en .gitignore y NO debe subirse al repositorio.)

# URL base del servidor. Para la demo local usa el mock incluido.
ICM_BASE_URL=http://127.0.0.1:8765

# Nombre del modelo/tenant en la plataforma ICM.
ICM_MODEL=DemoModel

# Token de autenticacion (Bearer). En la demo, el mock acepta este valor.
# En un entorno real, este seria un secreto entregado por la plataforma.
ICM_TOKEN=demo-token

# Puerto del mock server (por si 8000 esta reservado en tu sistema).
ICM_PORT=8765
